EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Platform-specific API base URLs used when EXPO_PUBLIC_API_BASE_URL is not set
# Web (browser / Expo web)
EXPO_PUBLIC_API_BASE_URL_WEB=http://localhost:8000

# Android emulator (10.0.2.2 points back to your host machine)
EXPO_PUBLIC_API_BASE_URL_ANDROID=http://10.0.2.2:8000

